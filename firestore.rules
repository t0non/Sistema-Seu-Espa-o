rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    function isValidQuote(data) {
      return data.clientName is string && data.clientName.size() > 0 &&
             data.serviceType is string &&
             data.items is list &&
             data.totalAmount is number &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdBy == request.auth.uid;
    }

    match /quotes/{quoteId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /serviceTypes/{typeId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
